                          </cv:Point>
                          <cv:Point>
                            <cv:X>76</cv:X>
                            <cv:Y>539</cv:Y>
                          </cv:Point>
                        </cv:ArrayOfPoint>
                      </cv:Regions>
                      <cv:MaskType>ToZero</cv:MaskType>
                      <cv:FillValue>
                        <cv:Val0>255</cv:Val0>
                        <cv:Val1>255</cv:Val1>
                        <cv:Val2>255</cv:Val2>
                        <cv:Val3>255</cv:Val3>
                      </cv:FillValue>
                    </Combinator>
                  </Expression>
                  <Expression xsi:type="PropertySource" TypeArguments="cv:CropPolygon,p1:Point[][]">
                    <MemberName>Regions</MemberName>
                    <Value>
